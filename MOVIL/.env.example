# URL base del backend (producción: https://senda-vida.onrender.com/api)
EXPO_PUBLIC_API_BASE_URL=https://senda-vida.onrender.com/api

# Radio de búsqueda de especies GBIF alrededor del GPS actual (km)
EXPO_PUBLIC_GBIF_SEARCH_RADIUS_KM=1

# API Key de Gemini (https://aistudio.google.com). Para EAS: eas secret:create --name EXPO_PUBLIC_GEMINI_API_KEY --value "tu-clave"
EXPO_PUBLIC_GEMINI_API_KEY=tu_api_key_aqui

# Firebase Realtime Database para chat comunitario (https://console.firebase.google.com)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
