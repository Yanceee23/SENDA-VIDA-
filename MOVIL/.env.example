# URL base del backend Spring Boot (puerto 8084).
# En celular físico: usa la IP de tu PC en la misma Wi-Fi (ej: http://192.168.1.100:8084/api).
# En emulador Android: usa http://10.0.2.2:8084/api
EXPO_PUBLIC_API_BASE_URL=http://TU_IP:8084/api

# API Key de Gemini (consíguela gratis en https://aistudio.google.com)
EXPO_PUBLIC_GEMINI_API_KEY=tu_api_key_aqui
